rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // -------------------------------------------------------------------------
    // GLOBAL HELPERS
    // -------------------------------------------------------------------------
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return request.auth.token.email_verified == true;
    }

    function getUserRole(uid) {
      return get(/databases/$(database)/documents/users/$(uid)).data.role;
    }

    function isSuperAdmin() {
      return isSignedIn() && getUserRole(request.auth.uid) == 'superadmin';
    }

    function isStaff() {
      return isSignedIn() && getUserRole(request.auth.uid) == 'staff';
    }

    function isActive() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.active == 'active';
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // -------------------------------------------------------------------------
    // COLLECTIONS
    // -------------------------------------------------------------------------

    // Catch-all deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Health Check / Handshake (Exempt from strict catch-all)
    match /test/connection {
      allow read: if true;
    }

    // Users Collection
    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isSuperAdmin() || isStaff());
      
      // Auto-profile creation for new users
      allow create: if isSignedIn() && request.auth.uid == userId && (
        (incoming().role == 'client' || (incoming().role == 'superadmin' && request.auth.token.email in ['jk2020.vtcc@gmail.com', 'admin@nextgenbuildlabs.com'])) && 
        incoming().active == 'active' &&
        incoming().uid == userId
      );

      // Admins manage state
      allow update: if isSuperAdmin() || (
        isSignedIn() && request.auth.uid == userId && isActive() &&
        incoming().diff(existing()).affectedKeys().hasOnly(['displayName'])
      );
    }
    
    // Explicitly allow Admins to list the users collection
    match /users {
      allow list: if isSuperAdmin() || isStaff();
    }

    // Projects Collection
    match /projects/{projectId} {
      allow read: if isSignedIn() && isActive() && (
        isSuperAdmin() || isStaff() ||
        resource.data.clientId == request.auth.uid
      );
      allow create, update, delete: if isSuperAdmin() || isStaff();
    }

    // Clients Collection
    match /clients/{clientId} {
      allow read: if isSignedIn() && (isSuperAdmin() || isStaff() || request.auth.uid == clientId);
      allow create, update, delete: if isSuperAdmin() || isStaff();
    }

    // Leads Collection (CRM)
    match /leads/{leadId} {
      allow read, create, update, delete: if isSuperAdmin() || isStaff();
      // Public contact form can create leads
      allow create: if true; 
    }

    // Invoices Collection (Financials)
    match /invoices/{invoiceId} {
      allow read: if isSignedIn() && (isSuperAdmin() || isStaff() || resource.data.clientId == request.auth.uid);
      allow create, update, delete: if isSuperAdmin();
    }

    // Tickets Collection (Support)
    match /tickets/{ticketId} {
      allow read: if isSignedIn() && (isSuperAdmin() || isStaff() || resource.data.clientId == request.auth.uid);
      allow create: if isSignedIn() && isActive();
      allow update, delete: if isSuperAdmin() || isStaff() || (isSignedIn() && isActive() && resource.data.clientId == request.auth.uid);
    }

    // Notifications (New)
    match /notifications/{notifId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isSuperAdmin();
    }
  }
}
